# Copy this file to .env at the repo root (docker-compose reads it) and fill in real keys.
# Never commit the real .env file.

# Anthropic Claude API — escalation tier for the Member AI Hub / Concierge
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-5

# Google AI Studio — hosts Gemma, the primary responder for the Member AI Hub / Concierge
GOOGLE_AI_STUDIO_API_KEY=your-google-ai-studio-key-here
GEMMA_MODEL=gemma-4-26b-a4b-it

# n8n — optional webhook for real SMS/Email follow-ups triggered via POST /api/cases/:id/notify.
# Leave unset to get a mock success response (safe for local dev/judging).
N8N_WEBHOOK_URL=

# Backend
PORT=4000

# Frontend (Vite) — base URL the SPA uses to reach the backend API
VITE_API_BASE_URL=http://localhost:4000
